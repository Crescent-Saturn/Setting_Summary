# --- 文件命名与保存 ---
-o "%(title)s.%(ext)s"

# --- 视频质量与格式 ---
-f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" # 优先下载MP4格式
--merge-output-format mp4          # 最终合并为mp4容器

# --- 下载设置 ---
--continue                         # 断点续传

# --- 字幕与元数据 ---
--embed-subs                       # 将字幕嵌入视频文件中
